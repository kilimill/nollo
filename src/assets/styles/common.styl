html,
body
	height 100%
	ff $inter
	font-weight 400
	font-size 14px
	line-height 14px
	color #222222
	// background-color #000
	// background-color #fff
	background-color #70e3b2
	// background-color $gray

#app
	min-height 100%

.main
	min-height 100vh
	height 100%
	
	&.log-in
		background url('~@/assets/img/details/bg-log.jpg')
		background-size contain
		background-repeat no-repeat
		background-position right bottom


.opacity 
	&-50 
		opacity .5
	
	&-70 
		opacity .7

	&-30
		opacity .3

.align
	&-ctr
		text-align center

.mb 
	&-4
		margin-bottom 4px

	&-8 
		margin-bottom 8px

	&-12
		margin-bottom 12px

	&-16
		margin-bottom 16px

	&-24 
		margin-bottom 24px

	&-32 
		margin-bottom 32px

	&-40
		margin-bottom 40px

	&-48
		margin-bottom 48px

.ml
	&-8 
		margin-left 8px

	&-16
		margin-left 16px

	&-24 
		margin-left 24px

	&-32 
		margin-left 32px

	&-40
		margin-left 40px

.mr
	&-8 
		margin-right 8px

	&-16
		margin-right 16px

	&-24 
		margin-right 24px

	&-32 
		margin-right 32px

	&-40
		margin-right 40px

// .main 
// 	&__content
.container
	padding 0 64px

	&-mid
		width 894px
		padding 0 15px
		margin 0 auto

.info
	display flex

	&__inner
		width 752px
		margin-right var(--offset-up-mid)

.performance
	display flex
	justify-content space-between
	align-items center
	
	&__item
		width 192px
		min-height 176px
		margin-left var(--offset-up-mid)
		display flex
		justify-content center
		align-items center
		flex-direction column
		background-color #fff
		border-radius 24px

		&:first-child
			padding var(--offset-big)
			display block
			width 880px
			margin-left 0

.logo
	width 88px
	height 56px
	object-fit cover

.wrapper
	display flex

	&_v-ctr
		align-items center

	&_h-btw
		justify-content space-between	


.details
	display flex

	&__item
		margin-left var(--offset-mid)
		display flex
		align-items center

		&:first-child
			margin-left 0

	.icon
		width 16px
		height 16px
		margin-right 8px

		path
			stroke #444444

	.controls_small
		color #444444

.icon
	width 24px
	height 24px

	path,
	rect,
	circle
		stroke $black

	&_green
		path,
		rect
			stroke $green

		circle
			fill $green


.border-btm
	pos relative
	padding-bottom 25px

	&:before
		content ''
		pos absolute
		bottom 0
		left 0
		width 100%
		height 1px
		background-color #222222
		opacity 0.32

.total 
	display: flex;	
	justify-content space-between
	align-items center
	border-radius: var(--radius-8);
	padding: 8px 16px;
	background-color: #fff;
	margin-top auto


.social 
	&__item 
		display: inline-block;
		margin-left: 12px;

		&:first-child 
			margin-left: 0;

	&__btn 
		display: block;
		padding 5px
		line-height 0

	.icon 
		width: 16px;
		height: 16px;

.calendar 
	width 100%

body
	.dp
		&__theme_light 
			--dp-background-color: #FFFFFF;
			--dp-text-color: #212121;
			--dp-hover-icon-color: #BFFDE3 ;
			--dp-hover-color: #E6FEF4;
			--dp-hover-text-color: #049A5B;
			--dp-hover-icon-color: #BFFDE3;
			--dp-primary-color: $green;

		&__today
			border none

		&__input
			height var(--heigth-elems)
			background-color #F5F5F5
			border none
			border-radius var(--radius-def)
			padding-left 72px

			&:placeholder
				color #222222 !important

			&_icon
				margin-left 24px

		&__calendar
			&_header
				justify-content space-between
				position relative
				color $green
				text-transform capitalize
				opacity 0.5

				&_item
					display flex
					align-items center
					justify-content center

				&_separator
					display none

			&_item,
			&_header
				font-size 12px
				line-height 12px
				font-weight 500

			&_next
				margin-left 0

			&_wrap
				ff $inter

		&__menu
			border-radius var(--radius-def)
			border none
			padding 24px 24px 32px 24px
			box-shadow: 0px 15px 39px -31px rgba(0, 0, 0, 0.11);

		&__range_between
			background-color #E6FEF4

		&__range
			&_start,
			&_end
				border-radius var(--radius-8)
		
		&__flex_display
			.dp__instance_calendar
				.dp__month_year_col_nav
					display inline-block
					top 50%
					transform translateY(-50%)
					position absolute
					right 0

				&:first-child
					margin-right 30px

					.dp__month_year_col_nav
						right auto
						left 0

		&__month_year
			&_select
				font-weight 500
				font-size 16px
				line-height 20px
				margin-right 5px
				width auto
				text-transform capitalize

			&_row
				position relative
				display flex
				justify-content center
				margin-bottom 24px

		&__cell_inner
			padding 10px

			