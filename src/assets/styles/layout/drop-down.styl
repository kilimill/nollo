.drop-down
  position absolute
  z-index 5
  background-color #FFFFFF
  border-radius 12px
  top 100%
  width 100%
  box-shadow 0px 15px 39px -31px rgba(0, 0, 0, 0.11)
  overflow hidden
  opacity 0
  transition opacity .2s

  &__btn
    width 100%
    display flex
    font-size 16px
    line-height 20px
    align-items center
    padding 0 16px
    transition background-color .3s, height .4s 

  .icon
    margin-right 12px

  &__parent
    position relative

    .drop-down
      opacity 0
      height 0
      top 130%

      &__btn
        padding 6px 24px
        opacity .5

        &.active
          opacity 1

    &.open
      .drop-down
        padding 10px 0
        opacity 1
        height auto     


.header__profile

  .drop-down__btn
    height 0

    &:hover
      background-color #E6FEF4
    

  &:hover
    .drop-down
      height auto
      opacity 1

      &__btn
        height 56px